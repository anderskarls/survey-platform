generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  code      String    @unique
  createdAt DateTime  @default(now())
  topics    Topic[]
  surveys   Survey[]
  students  Student[]
  units     Unit[]
}

model Unit {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  lessons     Json?
  period      String?
  goals       String[] @default([])
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  surveys     Survey[]

  @@unique([courseId, title])
}

model Student {
  id           Int        @id @default(autoincrement())
  number       Int
  username     String     @unique
  passwordHash String
  personKey    String?    // samma nyckel = samma fysiska elev i flera kurser
  courseId      Int
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  responses         Response[]
  flaggedQuestions   FlaggedQuestion[]
  drafts            DraftResponse[]
  assignmentFeedbacks AssignmentFeedback[]
  practiceAttempts   PracticeAttempt[]

  @@unique([courseId, number])
  @@index([personKey])
}

model Topic {
  id        Int        @id @default(autoincrement())
  name      String
  courseId   Int
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]

  @@unique([courseId, name])
}

model Question {
  id              Int              @id @default(autoincrement())
  text            String
  type            String           // MULTIPLE_CHOICE | FREE_TEXT | REFLECTION
  topicId         Int
  topic           Topic            @relation(fields: [topicId], references: [id])
  options         QuestionOption[]
  surveyQuestions SurveyQuestion[]
  answers         Answer[]
  flaggedBy       FlaggedQuestion[]
  practiceAttempts PracticeAttempt[]
}

model QuestionOption {
  id         Int      @id @default(autoincrement())
  text       String
  isCorrect  Boolean  @default(false)
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Survey {
  id          Int              @id @default(autoincrement())
  title       String
  description String           @default("")
  shareCode   String           @unique
  mode        String           @default("SURVEY") // SURVEY | QUIZ
  lockMode    Boolean          @default(false)
  courseId     Int
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  unitId      Int?
  unit        Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lesson      Int?
  createdAt   DateTime         @default(now())
  questions   SurveyQuestion[]
  responses   Response[]
  drafts      DraftResponse[]

  @@index([unitId])
}

model SurveyQuestion {
  id         Int      @id @default(autoincrement())
  surveyId   Int
  questionId Int
  order      Int
  survey     Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([surveyId, questionId])
}

model Response {
  id                  Int      @id @default(autoincrement())
  surveyId            Int
  studentId           Int
  createdAt           DateTime @default(now())
  lockModeViolations  Int      @default(0)
  survey              Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  student             Student  @relation(fields: [studentId], references: [id])
  answers             Answer[]

  @@index([surveyId, studentId])
  @@index([surveyId])
  @@index([studentId])
}

model Answer {
  id         Int      @id @default(autoincrement())
  responseId Int
  questionId Int
  value      String
  feedback   String?
  isCorrect  Boolean?
  response   Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([questionId])
}

model FlaggedQuestion {
  id         Int      @id @default(autoincrement())
  studentId  Int
  questionId Int
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([studentId, questionId])
  @@index([studentId])
}

model DraftResponse {
  id        Int      @id @default(autoincrement())
  surveyId  Int
  studentId Int
  answers   String   // JSON: Record<questionId, value>
  updatedAt DateTime @updatedAt

  survey  Survey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([surveyId, studentId])
  @@index([studentId])
}

model PracticeAttempt {
  id         Int      @id @default(autoincrement())
  studentId  Int
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String
  isCorrect  Boolean?
  createdAt  DateTime @default(now())

  @@index([studentId, questionId])
  @@index([studentId, createdAt])
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
}

model AssignmentFeedback {
  id        Int       @id @default(autoincrement())
  studentId Int
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title     String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([studentId, createdAt])
}
