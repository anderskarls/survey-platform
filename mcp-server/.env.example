# Kopiera denna fil till .env och fyll i din riktiga Neon-anslutningsstrang.
# .env ar gitignorerad och stannar lokalt pa din maskin.

# Neon Postgres - anvand den serverlosa/poolade anslutningsstrangen.
# MCP-servern ansluter via WebSocket (port 443) sa den fungerar aven
# bakom natverk som blockerar direkta Postgres-anslutningar (TCP 5432).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# Endast for HTTP-servern (npm run start:http) - inte for MCP via Claude Code.
# MCP_HTTP_TOKEN="valj-en-lang-hemlig-strang"
# MCP_HTTP_PORT=3002
# MCP_HTTP_HOST=127.0.0.1
