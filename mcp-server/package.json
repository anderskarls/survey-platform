{
  "name": "survey-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "sync-schema": "node scripts/sync-schema.mjs",
    "prebuild": "npm run sync-schema && npx prisma generate",
    "build": "tsc",
    "predev": "npm run sync-schema",
    "predev:http": "npm run sync-schema",
    "start": "node dist/server.js",
    "start:http": "node dist/http-server.js",
    "dev": "npx tsx src/server.ts",
    "dev:http": "npx tsx src/http-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nanoid": "^5.1.6",
    "papaparse": "^5.4.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.15",
    "@types/ws": "^8.5.13",
    "prisma": "^6.19.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
